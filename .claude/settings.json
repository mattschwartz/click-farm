{
  "permissions": {
    "allow": [
      "Bash(bash .frames/sdlc/tools/board.sh*)",
      "Bash(bash .frames/sdlc/tools/task.sh*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "in-process",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/install-frames.sh",
            "statusMessage": "Discovering frames..."
          }
        ]
      }
    ]
  }
}